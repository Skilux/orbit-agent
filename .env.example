# Orbit — copy to .env and fill in. NEVER commit .env.
# .env is gitignored; this template ships safely.

# ─── LLM (Hermes agent) ────────────
# The agent reads these three. Point at any provider you have access to
# (OpenAI, a LiteLLM proxy, OpenRouter, a local server, …). You can also
# reconfigure interactively later with `hermes model`.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ─── Bloomreach Engagement sandbox (custom write-MCP) ───────────────
# Engagement → Project settings (token) and Access Management → API (key/secret).
BR_PROJECT_TOKEN=
BR_API_KEY=
BR_API_SECRET=
BR_BASE_TRACK=https://api.exponea.com/track/v2
BR_BASE_DATA=https://api.exponea.com/data/v2

# ─── MCP server bind ────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Transport for the custom write-MCP: `http` (default) or `stdio`.
MCP_TRANSPORT=http

# Bloomreach MCP URL as the agent sees it.
#   Local run : http://localhost:8000/mcp   (default below)
#   Docker    : overridden to http://bloomreach-mcp:8000/mcp by docker-compose
BLOOMREACH_MCP_URL=http://localhost:8000/mcp

# ─── Loomi MCP (read-only, OAuth — no trailing slash) ───────────────
LOOMI_MCP_URL=https://loomi-mcp-alpha.bloomreach.com/mcp

# ─── Docker (macOS: run `id -u` / `id -g` and set these) ────────────
UID=1000
GID=1000
