 0; font-family: Helvetica, Arial, sans-serif; font-size:12px; line-height:18px; color:#a99b8b;\">\n                            Plus free shipping on orders over $99.\n                          </p>\n                        </td>\n                      </tr>\n                    </table>\n                  </td>\n                </tr>\n              </table>\n\n              <!-- CTA button (bulletproof) -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td align=\"center\" class=\"pa-px\" style=\"padding:30px 48px 12px 48px;\">\n                    <!--[if mso]>\n                    <v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"#\" style=\"height:54px;v-text-anchor:middle;width:300px;\" arcsize=\"6%\" strokecolor=\"#b14f35\" fillcolor=\"#b14f35\">\n                      <w:anchorlock/>\n                      <center style=\"color:#ffffff;font-family:Helvetica,Arial,sans-serif;font-size:13px;letter-spacing:2px;font-weight:bold;\">SHOP THE NEW COLLECTION</center>\n                    </v:roundrect>\n                    <![endif]-->\n                    <!--[if !mso]><!-- -->\n                    <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" align=\"center\" style=\"margin:0 auto;\">\n                      <tr>\n                        <td class=\"pa-hover-cta\" align=\"center\" bgcolor=\"#b14f35\" style=\"background-color:#b14f35; border-radius:3px;\">\n                          <a href=\"#\" style=\"display:inline-block; padding:17px 44px; font-family: Helvetica, Arial, sans-serif; font-size:13px; letter-spacing:2px; text-transform:uppercase; color:#ffffff; text-decoration:none; font-weight:bold;\">\n                            Shop the New Collection\n                          </a>\n                        </td>\n                      </tr>\n                    </tab