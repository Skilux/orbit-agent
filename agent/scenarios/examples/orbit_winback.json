            "jinja_html": "<!DOCTYPE html>\n<html lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\" xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\n  <meta name=\"x-apple-disable-message-reformatting\">\n  <meta name=\"color-scheme\" content=\"light\">\n  <meta name=\"supported-color-schemes\" content=\"light\">\n  <title>We've missed you at Pacific Apparel</title>\n  <!--[if mso]>\n  <noscript>\n    <xml>\n      <o:OfficeDocumentSettings>\n        <o:PixelsPerInch>96</o:PixelsPerInch>\n      </o:OfficeDocumentSettings>\n    </xml>\n  </noscript>\n  <![endif]-->\n  <!-- Progressive-enhancement styles only. Base layout works from inline styles alone. -->\n  <style>\n    body { margin: 0; padding: 0; width: 100% !important; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }\n    table { border-collapse: collapse !important; }\n    img { border: 0; outline: none; text-decoration: none; -ms-interpolation-mode: bicubic; }\n    a { text-decoration: none; }\n    .pa-hover-cta:hover { background-color: #8a3f2b !important; }\n    .pa-cat-link:hover { color: #b14f35 !important; }\n    @media only screen and (max-width: 600px) {\n      .pa-container { width: 100% !important; }\n      .pa-px { padding-left: 28px !important; padding-right: 28px !important; }\n      .pa-h1 { font-size: 30px !important; line-height: 38px !important; }\n      .pa-offer-num { font-size: 52px !important; line-height: 52px !important; }\n      .pa-stack { display: block !important; width: 100% !important; }\n      .pa-cat-cell { display: block !important; width: 100% !important; padding: 0 0 24px 0 !important; }\n      .pa-cat-img { width: 100% !important; height: auto !important; }\n      .pa-hide-sm { display: none !important; }\n    }\n  </style>\n</head>\n<body style=\"margin:0; padding:0; background-color:#f3ede4; color:#2b2724; font-family: Helvetica, Arial, sans-serif;\">\n\n  <!-- Preheader (hidden preview text) -->\n  <div style=\"display:none; font-size:1px; line-height:1px; max-height:0; max-width:0; opacity:0; overflow:hidden; mso-hide:all; color:#f3ede4;\">\n    We saved your spot &mdash; {{ customer.discount_tier | default('20') }}% off inside.\n    &nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;\n  </div>\n\n  <!-- Fluid outer wrapper -->\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background-color:#f3ede4;\">\n    <tr>\n      <td align=\"center\" style=\"padding:0;\">\n\n        <!--[if mso]><table role=\"presentation\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"><tr><td><![endif]-->\n        <table role=\"presentation\" class=\"pa-container\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" align=\"center\" style=\"width:600px; max-width:600px; margin:0 auto;\">\n\n          <!-- Top spacer + eyebrow -->\n          <tr>\n            <td align=\"center\" class=\"pa-px\" style=\"padding:28px 48px 0 48px;\">\n              <p style=\"margin:0; font-family: Helvetica, Arial, sans-serif; font-size:11px; letter-spacing:3px; text-transform:uppercase; color:#9a8f80;\">\n                Spring 2026 Collection\n              </p>\n            </td>\n          </tr>\n\n          <!-- Header / wordmark -->\n          <tr>\n            <td align=\"center\" class=\"pa-px\" style=\"padding:14px 48px 22px 48px; border-bottom:1px solid #e0d6c8;\">\n              <a href=\"#\" style=\"text-decoration:none;\">\n                <span style=\"font-family: Georgia, 'Times New Roman', Times, serif; font-size:26px; letter-spacing:5px; color:#2b2724; text-transform:uppercase; font-weight:normal;\">Pacific</span>\n                <span style=\"font-family: Georgia, 'Times New Roman', Times, serif; font-size:26px; letter-spacing:5px; color:#b14f35; text-transform:uppercase; font-weight:normal;\">&nbsp;Apparel</span>\n              </a>\n            </td>\n          </tr>\n\n          <!-- White content card -->\n          <tr>\n            <td style=\"padding:0; background-color:#fbf8f3;\">\n\n\n              <!-- Hero copy -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td class=\"pa-px\" style=\"padding:40px 48px 8px 48px;\">\n                    <p style=\"margin:0 0 14px 0; font-family: Helvetica, Arial, sans-serif; font-size:11px; letter-spacing:3px; text-transform:uppercase; color:#b14f35;\">\n                      Modern Elegance\n                    </p>\n                    <h1 class=\"pa-h1\" style=\"margin:0 0 18px 0; font-family: Georgia, 'Times New Roman', Times, serif; font-weight:normal; font-size:38px; line-height:46px; color:#2b2724;\">\n                      We&rsquo;ve missed you,<br>{{ customer.first_name | default('there') }}.\n                    </h1>\n                    <p style=\"margin:0; font-family: Georgia, 'Times New Roman', Times, serif; font-size:17px; line-height:28px; color:#5a5249;\">\n                      It&rsquo;s been a little while. The Spring 2026 collection has just landed &mdash; lighter layers, refined tailoring, and the easy pieces you&rsquo;ll reach for all season. We saved something to welcome you back.\n                    </p>\n                  </td>\n                </tr>\n              </table>\n\n              <!-- Offer block -->\n              <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n                <tr>\n                  <td class=\"pa-px\" style=\"padding:34px 48px 6px 48px;\">\n                    <table role=\"presentation\" width=\"100%\" cellpadding=