border:0; border-radius:3px;\">\n                          </a>\n                          <p style=\"margin:12px 0 0 0;\">\n                            <a href=\"#\" class=\"pa-cat-link\" style=\"font-family: Georgia, 'Times New Roman', Times, serif; font-size:15px; letter-spacing:1px; color:#2b2724; text-decoration:none;\">Women</a>\n                          </p>\n                        </td>\n                        <!-- Men -->\n                        <td class=\"pa-cat-cell\" valign=\"top\" width=\"33.33%\" align=\"center\" style=\"padding:0 8px;\">\n                          <a href=\"#\" style=\"text-decoration:none;\">\n                            <img class=\"pa-cat-img\" src=\"https://bloomreach.getbynder.com/asset/38b46c25-6f80-41d9-b404-619eb186b1dd/online/sweater2.png\" width=\"170\" alt=\"Shop Men's new arrivals\" style=\"display:block; width:100%; max-width:170px; height:auto; border:0; border-radius:3px;\">\n                          </a>\n                          <p style=\"margin:12px 0 0 0;\">\n                            <a href=\"#\" class=\"pa-cat-link\" style=\"font-family: Georgia, 'Times New Roman', Times, serif; font-size:15px; letter-spacing:1px; color:#2b2724; text-decoration:none;\">Men</a>\n                          </p>\n                        </td>\n                        <!-- Bags -->\n                        <td class=\"pa-cat-cell\" valign=\"top\" width=\"33.33%\" align=\"center\" style=\"padding:0 8px;\">\n                          <a href=\"#\" style=\"text-decoration:none;\">\n                            <img class=\"pa-cat-img\" src=\"https://pacific-demo-data.bloomreach.cloud/apparel/images/webp/gen_gptimage_1/bags/variants/110760_0_image.webp\" width=\"170\" alt=\"Shop Bags new arrivals\" style=\"display:block; width:100%; max-width:170px; height:auto; border:0; border-radius:3px;\">\n                          </a>\n                          <p style=\"margin:12px 0 0 0;\">\n                            <a href=\"#\" cla